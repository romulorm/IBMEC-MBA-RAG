# .env.example - Projeto Final (Aula 12). Copie para .env e preencha.

# --- Logs (verbosidade) ---
# DEBUG = maximo (sinais do probe, trechos, libs); INFO = decisoes; WARNING/ERROR = menos.
LOG_LEVEL=INFO

# --- LLM (AGNOSTICO a provedor; qualquer endpoint OpenAI-compativel) ---
# Troque os 3 valores para mudar de provedor. Exemplos:
#   Groq:       LLM_BASE_URL=https://api.groq.com/openai/v1        LLM_MODEL=llama-3.3-70b-versatile
#   OpenAI:     LLM_BASE_URL=https://api.openai.com/v1            LLM_MODEL=gpt-4o-mini
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1         LLM_MODEL=meta-llama/llama-3.3-70b-instruct
#   Together:   LLM_BASE_URL=https://api.together.xyz/v1          LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
#   DeepSeek:   LLM_BASE_URL=https://api.deepseek.com             LLM_MODEL=deepseek-chat
#   vLLM/local: LLM_BASE_URL=http://localhost:8000/v1            LLM_MODEL=<seu-modelo>
#   Ollama:     LLM_BASE_URL=http://localhost:11434/v1           LLM_MODEL=llama3.1
LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=coloque-sua-chave
LLM_MODEL=llama-3.3-70b-versatile
# (compat: se LLM_API_KEY ficar vazio, o app ainda aceita GROQ_API_KEY)
GROQ_API_KEY=

# --- Embedding (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# --- Docling (controle de memoria; evita 'std::bad_alloc' em PDFs grandes) ---
DOCLING_NUM_THREADS=2         # menos threads = menor pico de RAM (1-2 em maquinas modestas)
DOCLING_IMAGE_SCALE=1.0       # escala da imagem por pagina (menor = menos memoria)

# --- OpenSearch ---
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=
OPENSEARCH_PASS=
OPENSEARCH_INDEX=projeto_final

# --- API (opcional): chaves aceitas no header X-API-Key, separadas por virgula ---
API_KEYS=

# --- Interface Gradio (interface.py) ---
API_URL=http://localhost:8000
GRADIO_PORT=7860
API_KEY=                      # use apenas se API_KEYS estiver configurado acima

# --- LangFuse (opcional) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000
