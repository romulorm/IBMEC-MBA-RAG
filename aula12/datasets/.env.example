# --- OpenAI ---
OPENAI_API_KEY=sk-coloque-sua-chave-aqui

# --- LangFuse ---
LANGFUSE_PUBLIC_KEY=pk-lf-coloque-aqui
LANGFUSE_SECRET_KEY=sk-lf-coloque-aqui
LANGFUSE_NEXTAUTH_SECRET=gere-com-openssl-rand-hex-32
LANGFUSE_SALT=gere-com-openssl-rand-hex-16

# --- API Keys da RAG API ---
# Separe múltiplas chaves por vírgula
API_KEYS=dev-key-mba-2024,aluno-key-001

# --- OpenSearch (valores padrão para dev) ---
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=Admin@RAG1234!
OPENSEARCH_INDEX=rag_juridico_v1
