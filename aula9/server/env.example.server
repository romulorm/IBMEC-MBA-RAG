###########################################################################
### .env do LightRAG Server/WebUI - Aula 9 (Graph RAG)
### LLM = Groq | Embedding = Ollama bge-m3 | Rerank = Jina (API)
###
### COMO USAR:
###   1) copie este arquivo para a pasta da aula como .env:
###        Windows:  copy server\env.example.server ..\.env  (rode o server de aula9\)
###      ou simplesmente crie aula9\.env com este conteudo.
###   2) preencha LLM_BINDING_API_KEY (sua chave Groq) e RERANK_BINDING_API_KEY (Jina).
###   3) rode 'lightrag-server' de dentro da pasta aula9\ (assim WORKING_DIR=./rag_storage
###      aponta para o MESMO grafo que os scripts 01-04 constroem).
###   4) abra http://localhost:9621
###########################################################################

### Servidor
HOST=0.0.0.0
PORT=9621
WEBUI_TITLE='MBA RAG - Grafo Juridico'
WEBUI_DESCRIPTION='Graph RAG (LightRAG) - Aula 9'

### Diretorio de trabalho (grafo + vetores + kv).
### Rodando o server de dentro de aula9\, o padrao ./rag_storage ja aponta para o
### mesmo storage dos scripts. Se rodar de outro lugar, descomente e use caminho ABSOLUTO:
# WORKING_DIR=D:\IBMEC\MBA_RAG_CAG\aula9\rag_storage

### Idioma dos resumos de comunidade e da extracao
SUMMARY_LANGUAGE=Portuguese
ENTITY_EXTRACTION_USE_JSON=true

###########################################################################
### LLM - Groq (API OpenAI-compatible)
### NAO use modelo de raciocinio (gpt-oss) na indexacao (a doc do LightRAG desaconselha).
###########################################################################
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.groq.com/openai/v1
LLM_BINDING_API_KEY=gsk_L3yK6RjT2sR347S8jXcDWEqyQ3BlbkFJk1n0XwB9rP52h41M7Y
LLM_MODEL=llama-3.3-70b-versatile
MAX_ASYNC=4
# LLM_TIMEOUT=180
### contexto/tokens enviados ao LLM (ajuste se necessario)
# MAX_TOTAL_TOKENS=30000

###########################################################################
### Embedding - Ollama bge-m3 (1024 dimensoes)
### Antes: ollama pull bge-m3
### IMPORTANTE: o EMBEDDING_MODEL/DIM deve ser o MESMO usado na indexacao dos scripts
### (a Aula 9 ja padroniza bge-m3). Trocar exige re-indexar.
###########################################################################
EMBEDDING_BINDING=ollama
EMBEDDING_BINDING_HOST=http://localhost:11434
EMBEDDING_MODEL=bge-m3:latest
EMBEDDING_DIM=1024
OLLAMA_EMBEDDING_NUM_CTX=8192

###########################################################################
### Rerank - Jina AI (API de nuvem). Precisa de RERANK_BINDING_API_KEY.
### Modelo multilingue (bom para portugues). Rerank melhora 'hybrid/mix'.
###########################################################################
RERANK_BINDING=jina
RERANK_MODEL=jina-reranker-v2-base-multilingual
RERANK_BINDING_HOST=https://api.jina.ai/v1/rerank
RERANK_BINDING_API_KEY=jina_b13e72895d504cdfbd8bf2d69d0515c0ryeKa5EXjpG7VHgn9fGAIHqlWDah
RERANK_BY_DEFAULT=True
# MIN_RERANK_SCORE=0.0

### Alternativa: Cohere (descomente e comente o bloco Jina acima)
# RERANK_BINDING=cohere
# RERANK_MODEL=rerank-v3.5
# RERANK_BINDING_HOST=https://api.cohere.com/v2/rerank
# RERANK_BINDING_API_KEY=COLE_AQUI_SUA_CHAVE_COHERE

### Para DESLIGAR o rerank (servidor roda sem chave de rerank):
# RERANK_BINDING=null

###########################################################################
### Storage NATIVO em arquivo (igual aos scripts 01-04). NAO mudar p/ abrir
### o mesmo grafo: file-based (NetworkX + NanoVectorDB + JSON).
###########################################################################
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage

### (opcional) chave para proteger a API/WebUI
# LIGHTRAG_API_KEY=defina-uma-chave
