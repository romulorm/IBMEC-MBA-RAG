<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Aula 1 — Fundamentos | MBA RAG &amp; CAG</title>
<style>

:root {
  --bg: #080d1a;
  --bg2: #0f1729;
  --glass: rgba(255,255,255,0.04);
  --glass-border: rgba(255,255,255,0.08);
  --text: #e2e8f0;
  --text-muted: #94a3b8;
  --code-bg: #020714;
  --radius: 16px;
  --transition: 0.4s cubic-bezier(0.4,0,0.2,1);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; background: var(--bg); color: var(--text); font-family: 'Inter', system-ui, sans-serif; }

/* ── SLIDES WRAPPER ── */
.slides-container { width: 100vw; height: 100vh; overflow: hidden; position: relative; }
.slides-track { display: flex; height: 100%; transition: transform var(--transition); will-change: transform; }
.slide { min-width: 100vw; height: 100vh; display: flex; flex-direction: column; padding: 0; position: relative; overflow: hidden; }
.slide::before { content:''; position:absolute; inset:0; background: radial-gradient(ellipse at 20% 30%, rgba(var(--ac1),0.12) 0%, transparent 60%), radial-gradient(ellipse at 80% 70%, rgba(var(--ac2),0.08) 0%, transparent 60%); pointer-events:none; z-index:0; }

/* ── SLIDE HEADER ── */
.slide-header { padding: 2rem 3rem 1rem; display: flex; align-items: center; gap: 1rem; position: relative; z-index: 1; border-bottom: 1px solid var(--glass-border); }
.slide-icon { font-size: 2.2rem; }
.slide-header h2 { font-size: 1.6rem; font-weight: 700; letter-spacing: -0.03em; }
.slide-header h2 span { opacity: 0.5; font-weight: 400; font-size: 1rem; margin-left: .5rem; }
.slide-num { margin-left: auto; font-size: .8rem; color: var(--text-muted); background: var(--glass); border: 1px solid var(--glass-border); border-radius: 20px; padding: .25rem .75rem; }

/* ── SLIDE BODY ── */
.slide-body { flex: 1; padding: 1.5rem 3rem 1rem; position: relative; z-index: 1; overflow-y: auto; display: flex; gap: 2rem; }
.slide-body::-webkit-scrollbar { width: 4px; } .slide-body::-webkit-scrollbar-thumb { background: var(--glass-border); border-radius: 2px; }

/* ── CONTENT COLUMN ── */
.content-col { flex: 1; display: flex; flex-direction: column; gap: 1rem; min-width: 0; }
.lead-text { font-size: 1.05rem; line-height: 1.65; color: #cbd5e1; border-left: 3px solid; padding-left: 1rem; border-radius: 0 4px 4px 0; }
.bullet-list { list-style: none; display: flex; flex-direction: column; gap: .6rem; }
.bullet-list li { padding: .65rem 1rem; background: var(--glass); border: 1px solid var(--glass-border); border-radius: 10px; font-size: .95rem; line-height: 1.5; }
.bullet-list li em { color: #f59e0b; font-style: normal; }

/* ── CODE BLOCK ── */
.code-col { flex: 1; min-width: 0; }
.code-wrap { background: var(--code-bg); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; overflow: hidden; }
.code-header { padding: .5rem 1rem; background: rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.06); display: flex; align-items: center; gap: .5rem; font-size: .75rem; color: var(--text-muted); }
.code-dots { display: flex; gap: .4rem; }
.code-dots span { width: 12px; height: 12px; border-radius: 50%; }
.dot-r { background: #ff5f56; } .dot-y { background: #ffbd2e; } .dot-g { background: #27c93f; }
pre { padding: 1.25rem; font-family: 'JetBrains Mono', 'Fira Code', monospace; font-size: .8rem; line-height: 1.6; overflow-x: auto; color: #e2e8f0; }
pre::-webkit-scrollbar { height: 4px; } pre::-webkit-scrollbar-thumb { background: var(--glass-border); }

/* ── DIAGRAM ── */
.diagram-col { flex: 1; display: flex; align-items: center; }
.diagram { width: 100%; background: var(--glass); border: 1px solid var(--glass-border); border-radius: 14px; padding: 1.5rem; }
.d-flow { display: flex; align-items: center; gap: .6rem; flex-wrap: wrap; }
.d-row { display: flex; align-items: center; gap: 1rem; }
.d-col { display: flex; flex-direction: column; align-items: center; gap: .5rem; }
.d-step { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: .5rem .9rem; font-size: .85rem; text-align: center; white-space: nowrap; line-height: 1.4; }
.d-step.small { font-size: .75rem; padding: .4rem .7rem; }
.d-step.tiny { font-size: .7rem; padding: .3rem .5rem; }
.d-step.cyan { border-color: #00d4ff; color: #00d4ff; background: rgba(0,212,255,0.08); }
.d-step.purple { border-color: #7c3aed; color: #a78bfa; background: rgba(124,58,237,0.1); }
.d-step.green { border-color: #10b981; color: #34d399; background: rgba(16,185,129,0.08); }
.d-step.blue { border-color: #3b82f6; color: #60a5fa; background: rgba(59,130,246,0.08); }
.d-step.orange { border-color: #f59e0b; color: #fbbf24; background: rgba(245,158,11,0.08); }
.d-step.red { border-color: #ef4444; color: #f87171; background: rgba(239,68,68,0.08); }
.d-arr { color: #475569; font-size: 1.2rem; font-weight: 300; }
.d-arr.down { transform: rotate(90deg); display: block; text-align: center; }
.d-note { margin-top: 1rem; font-size: .8rem; color: var(--text-muted); text-align: center; font-style: italic; }
.d-box { border: 1px solid; border-radius: 10px; padding: .75rem 1rem; text-align: center; font-size: .85rem; line-height: 1.5; }
.d-box.red { border-color: #ef4444; color: #f87171; background: rgba(239,68,68,0.08); }
.d-box.green { border-color: #10b981; color: #34d399; background: rgba(16,185,129,0.08); }
.d-box.cyan { border-color: #00d4ff; color: #00d4ff; background: rgba(0,212,255,0.06); }
.d-box.purple { border-color: #7c3aed; color: #a78bfa; background: rgba(124,58,237,0.08); }
.d-box.blue { border-color: #3b82f6; color: #60a5fa; background: rgba(59,130,246,0.08); }
.d-box.orange { border-color: #f59e0b; color: #fbbf24; background: rgba(245,158,11,0.08); }
.d-box.small { font-size: .75rem; padding: .5rem .75rem; }
.d-label { font-size: .8rem; font-weight: 600; margin-bottom: .4rem; }
.d-layers { display: flex; flex-direction: column; gap: .5rem; }
.d-layer { border: 1px solid; border-radius: 10px; padding: .75rem 1rem; }
.d-layer-label { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; margin-bottom: .5rem; color: var(--text-muted); }
.d-table { width: 100%; border-collapse: collapse; font-size: .85rem; }
.d-table th { padding: .5rem .75rem; text-align: left; color: var(--text-muted); border-bottom: 1px solid var(--glass-border); }
.d-table td { padding: .5rem .75rem; border-bottom: 1px solid rgba(255,255,255,0.04); }
.d-metric-box { flex: 1; min-width: 130px; border: 1px solid; border-radius: 10px; padding: .75rem; text-align: center; }
.d-metric-title { font-weight: 700; font-size: .85rem; margin-bottom: .4rem; }
.d-metric-desc { font-size: .75rem; color: var(--text-muted); margin-bottom: .5rem; }
.d-metric-icon { font-size: 1.5rem; }

/* ── COVER SLIDE ── */
.slide-cover { background: linear-gradient(135deg, rgba(var(--ac1),.15) 0%, rgba(var(--ac2),.1) 100%); justify-content: center; align-items: center; }
.cover-inner { text-align: center; max-width: 800px; padding: 2rem; }
.cover-badge { display: inline-flex; align-items: center; gap: .5rem; background: var(--glass); border: 1px solid var(--glass-border); border-radius: 20px; padding: .4rem 1rem; font-size: .8rem; color: var(--text-muted); margin-bottom: 1.5rem; }
.cover-icon { font-size: 4rem; margin-bottom: 1rem; }
.cover-title { font-size: 3rem; font-weight: 800; letter-spacing: -0.04em; line-height: 1.1; margin-bottom: .75rem; }
.cover-subtitle { font-size: 1.3rem; color: var(--text-muted); margin-bottom: 2rem; }
.cover-meta { display: flex; justify-content: center; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem; }
.meta-chip { background: var(--glass); border: 1px solid var(--glass-border); border-radius: 8px; padding: .4rem .9rem; font-size: .82rem; }
.meta-chip span { color: var(--text-muted); }
.cover-objetivo { background: var(--glass); border: 1px solid var(--glass-border); border-radius: 12px; padding: 1rem 1.5rem; font-size: .9rem; line-height: 1.6; color: #cbd5e1; text-align: left; }
.cover-objetivo strong { color: var(--text); }

/* ── RESOURCES SLIDE ── */
.resources-grid { display: flex; flex-direction: column; gap: 1.5rem; }
.resource-section { }
.resource-section-title { font-size: .75rem; text-transform: uppercase; letter-spacing: .12em; color: var(--text-muted); margin-bottom: .75rem; display: flex; align-items: center; gap: .5rem; }
.resource-section-title::after { content: ''; flex: 1; height: 1px; background: var(--glass-border); }
.resource-cards { display: flex; flex-wrap: wrap; gap: .65rem; }
.resource-card { background: var(--glass); border: 1px solid var(--glass-border); border-radius: 10px; padding: .6rem 1rem; font-size: .8rem; color: var(--text); text-decoration: none; display: inline-flex; align-items: center; gap: .5rem; transition: all .2s; }
.resource-card:hover { border-color: rgba(var(--ac1),.6); background: rgba(var(--ac1),.08); transform: translateY(-2px); }
.resource-card .rc-icon { font-size: 1rem; }
.resource-card .rc-name { font-weight: 500; }
.resource-card .rc-type { color: var(--text-muted); font-size: .72rem; }

/* ── MAP SLIDE ── */
.map-grid { display: flex; flex-direction: column; gap: .75rem; }
.map-layer { border: 1px solid; border-radius: 12px; padding: .75rem 1.2rem; display: flex; align-items: center; gap: 1rem; }
.map-layer-name { font-weight: 700; font-size: .85rem; min-width: 100px; }
.map-techs { display: flex; flex-wrap: wrap; gap: .4rem; }
.map-tech { background: rgba(255,255,255,0.06); border-radius: 6px; padding: .25rem .6rem; font-size: .78rem; }

/* ── HIGHLIGHT SLIDE ── */
.highlight-banner { border: 1px solid; border-radius: 12px; padding: 1rem 1.5rem; font-size: 1rem; line-height: 1.65; font-weight: 500; }

/* ── NAVIGATION ── */
.nav-bar { position: fixed; bottom: 0; left: 0; right: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; padding: .75rem 2rem; background: rgba(8,13,26,.9); backdrop-filter: blur(12px); border-top: 1px solid var(--glass-border); }
.nav-btn { background: var(--glass); border: 1px solid var(--glass-border); color: var(--text); border-radius: 10px; padding: .5rem 1.25rem; cursor: pointer; font-size: .9rem; transition: all .2s; display: flex; align-items: center; gap: .5rem; }
.nav-btn:hover:not(:disabled) { border-color: rgba(var(--ac1),.7); background: rgba(var(--ac1),.1); }
.nav-btn:disabled { opacity: .3; cursor: not-allowed; }
.nav-dots { display: flex; gap: .5rem; align-items: center; flex-wrap: wrap; justify-content: center; max-width: 60%; }
.nav-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--glass-border); cursor: pointer; transition: all .2s; border: 1px solid transparent; }
.nav-dot.active { background: rgba(var(--ac1),1); transform: scale(1.3); }
.nav-dot:hover { background: rgba(var(--ac1),.5); }
.nav-home { background: var(--glass); border: 1px solid var(--glass-border); color: var(--text-muted); border-radius: 10px; padding: .35rem .75rem; cursor: pointer; font-size: .8rem; text-decoration: none; }
.nav-home:hover { color: var(--text); }
.nav-info { font-size: .8rem; color: var(--text-muted); }

/* ── PROGRESS BAR ── */
.progress-bar { position: fixed; top: 0; left: 0; height: 3px; background: linear-gradient(90deg, rgb(var(--ac1)), rgb(var(--ac2))); transition: width var(--transition); z-index: 200; }

/* ── SYNTAX HIGHLIGHT ── */
.kw { color: #c792ea; } .fn { color: #82aaff; } .str { color: #c3e88d; }
.cm { color: #546e7a; font-style: italic; } .num { color: #f78c6c; }
.var { color: #e2e8f0; } .op { color: #89ddff; } .cls { color: #ffcb6b; }
.dec { color: #f07178; }

/* responsive */
@media (max-width: 768px) {
  .slide-body { flex-direction: column; padding: 1rem 1.25rem; }
  .cover-title { font-size: 2rem; }
  .slide-header { padding: 1rem 1.25rem; }
  .slide-header h2 { font-size: 1.2rem; }
}

</style>
</head>
<body>
<div class="progress-bar" id="progressBar"></div>
<div class="slides-container">
  <div class="slides-track">
<div class="slide slide-cover" style="--ac1:0,212,255;--ac2:0,128,255"><div class="cover-inner"><div class="cover-badge">🎓 MBA RAG &amp; CAG · Aula 1 de 12</div><div class="cover-icon">🧠</div><div class="cover-title" style="background:linear-gradient(135deg,#00d4ff,#0080ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent">Fundamentos</div><div class="cover-subtitle">NLP, Embeddings, LLMs e Setup do Ambiente</div><div class="cover-meta"><div class="meta-chip"><span>⏱ </span>5 horas</div><div class="meta-chip"><span>📊 </span>35% Teoria / 65% Prática</div><div class="meta-chip"><span>⚙️ </span>OpenSearch · vLLM · LangFuse · BGE-M3 · FAISS…</div><div class="meta-chip"><span>📋 </span>Pré-req: Nenhum</div></div><div class="cover-objetivo"><strong>🎯 Objetivo:</strong> Construir os alicerces conceituais e práticos para compreender sistemas RAG e CAG: desde NLP básico até o panorama das 25 técnicas do curso.</div></div></div>
<div class="slide" style="--ac1:0,212,255;--ac2:0,128,255"><div class="slide-header" style="border-color:rgba(0,212,255,.25)"><span class="slide-icon">🚨</span><h2 style="color:#00d4ff">Por que RAG? O Problema dos LLMs<span>Aula 1</span></h2><span class="slide-num">1/8</span></div><div class="slide-body"><div class="content-col"><p class="lead-text" style="border-color:#00d4ff">LLMs são poderosos mas têm limitações críticas em contextos jurídicos e de segurança pública.</p><ul class="bullet-list"><li>🔴 Hallucination — inventa fatos com confiança (ex: cita artigo inexistente do CPP)</li><li>🔴 Knowledge cutoff — não conhece legislação ou jurisprudência recente</li><li>🔴 Sem fonte verificável — impossível auditar a origem das respostas</li><li>🔴 Contexto de janela limitado — não processa todo o acervo documental</li><li>✅ Solução: RAG injeta contexto recuperado de fontes verificáveis em tempo real</li></ul></div><div class="diagram-col">
<div class="diagram">
  <div class="d-row">
    <div class="d-box red">❌ LLM puro<br><small>Hallucination<br>Knowledge cutoff</small></div>
    <div class="d-arrow">→</div>
    <div class="d-box green">✅ RAG<br><small>Contexto verificável<br>Sem alucinação</small></div>
  </div>
  <div class="d-flow" style="margin-top:1rem">
    <span class="d-step">Query do usuário</span>
    <span class="d-arr">→</span>
    <span class="d-step cyan">Retriever</span>
    <span class="d-arr">→</span>
    <span class="d-step purple">Contexto real</span>
    <span class="d-arr">→</span>
    <span class="d-step green">LLM gera</span>
    <span class="d-arr">→</span>
    <span class="d-step blue">Resposta ✅</span>
  </div>
</div></div></div></div>
<div class="slide" style="--ac1:0,212,255;--ac2:0,128,255"><div class="slide-header" style="border-color:rgba(0,212,255,.25)"><span class="slide-icon">📝</span><h2 style="color:#00d4ff">Tópico 1 — NLP: Fundamentos<span>Aula 1</span></h2><span class="slide-num">2/8</span></div><div class="slide-body"><div class="content-col"><p class="lead-text" style="border-color:#00d4ff">Processamento de Linguagem Natural (NLP) é o campo da IA que permite às máquinas compreender e gerar linguagem humana.</p><ul class="bullet-list"><li>Bag-of-Words: representação esparsa, ignora ordem e semântica</li><li>TF-IDF: pesa termos pela frequência vs raridade no corpus</li><li>BM25: variação probabilística do TF-IDF, base do Elasticsearch/OpenSearch</li><li>Problema central: representar o <em>significado</em> do texto, não apenas as palavras</li></ul></div><div class="code-col"><div class="code-wrap"><div class="code-header"><div class="code-dots"><span class="dot-r"></span><span class="dot-y"></span><span class="dot-g"></span></div>Python 3.11+</div><pre><span class="kw">from</span> sklearn.feature_extraction.text <span class="kw">import</span> TfidfVectorizer

corpus = [
    <span class="str">&quot;o réu foi preso em flagrante&quot;</span>,
    <span class="str">&quot;habeas corpus impetrado pelo advogado&quot;</span>,
]
vec = <span class="cls">TfidfVectorizer</span>()
X = vec.<span class="fn">fit_transform</span>(corpus)
<span class="fn">print</span>(X.<span class="fn">toarray</span>())  <span class="cm"># matriz esparsa</span></pre></div></div></div></div>
<div class="slide" style="--ac1:0,212,255;--ac2:0,128,255"><div class="slide-header" style="border-color:rgba(0,212,255,.25)"><span class="slide-icon">📐</span><h2 style="color:#00d4ff">Tópico 2 — Embeddings Estáticos<span>Aula 1</span></h2><span class="slide-num">3/8</span></div><div class="slide-body"><div class="content-col"><p class="lead-text" style="border-color:#00d4ff">Word2Vec, GloVe e fastText representam palavras como vetores densos no espaço semântico.</p><ul class="bullet-list"><li>Word2Vec (2013): rede neural shallow, aprende de co-ocorrências — 'rei' - 'homem' + 'mulher' ≈ 'rainha'</li><li>GloVe: minimiza diferença entre log de co-ocorrências globais</li><li>fastText: decompõe palavras em subpalavras — lida com OOV</li><li>Limitação crítica: uma palavra = um vetor fixo, sem contexto (banco = instituição OU assento?)</li></ul></div><div class="code-col"><div class="code-wrap"><div class="code-header"><div class="code-dots"><span class="dot-r"></span><span class="dot-y"></span><span class="dot-g"></span></div>Python 3.11+</div><pre><span class="kw">from</span> gensim.models <span class="kw">import</span> Word2Vec

<span class="cm"># Treinar embeddings jurídicos</span>
sentences = [
    [<span class="str">&quot;réu&quot;</span>, <span class="str">&quot;habeas&quot;</span>, <span class="str">&quot;corpus&quot;</span>, <span class="str">&quot;STF&quot;</span>],
    [<span class="str">&quot;prisão&quot;</span>, <span class="str">&quot;preventiva&quot;</span>, <span class="str">&quot;decreto&quot;</span>],
]
model = <span class="cls">Word2Vec</span>(sentences, vector_size=<span class="num">100</span>, window=<span class="num">5</span>)
<span class="fn">print</span>(model.wv.<span class="fn">most_similar</span>(<span class="str">&quot;réu&quot;</span>, topn=<span class="num">3</span>))</pre></div></div></div></div>
<div class="slide" style="--ac1:0,212,255;--ac2:0,128,255"><div class="slide-header" style="border-color:rgba(0,212,255,.25)"><span class="slide-icon">🔮</span><h2 style="color:#00d4ff">Tópico 3 — Embeddings Contextuais &amp; BGE-M3<span>Aula 1</span></h2><span class="slide-num">4/8</span></div><div class="slide-body"><div class="content-col"><p class="lead-text" style="border-color:#00d4ff">BERT e seus descendentes geram vetores dependentes do contexto completo da sentença.</p><ul class="bullet-list"><li>BERT (2018): Transformer bidirecional — 'banco' tem vetor diferente em cada contexto</li><li>Sentence-Transformers: fine-tuning para similaridade entre frases (STS)</li><li>BGE-M3 (BAAI): estado-da-arte multilíngue, suporta 100+ idiomas e português jurídico</li><li>dim=1024, max_length=8192 — ideal para documentos jurídicos longos</li></ul></div><div class="code-col"><div class="code-wrap"><div class="code-header"><div class="code-dots"><span class="dot-r"></span><span class="dot-y"></span><span class="dot-g"></span></div>Python 3.11+</div><pre><span class="kw">from</span> FlagEmbedding <span class="kw">import</span> BGEM3FlagModel

model = <span class="cls">BGEM3FlagModel</span>(<span class="str">&quot;BAAI/bge-m3&quot;</span>, use_fp16=<span class="kw">True</span>)

queries = [<span class="str">&quot;prisão preventiva requisitos&quot;</span>]
docs = [<span class="str">&quot;Art. 312 CPP: A prisão preventiva poderá ser decretada...&quot;</span>]

q_emb = model.<span class="fn">encode</span>(queries, batch_size=<span class="num">4</span>)
d_emb = model.<span class="fn">encode</span>(docs, batch_size=<span class="num">4</span>)

<span class="cm"># Similaridade coseno</span>
<span class="kw">import</span> numpy <span class="kw">as</span> np
score = np.<span class="fn">dot</span>(q_emb[<span class="num">0</span>], d_emb[<span class="num">0</span>])
<span class="fn">print</span>(<span class="str">f&quot;Similaridade: {score:.4f}&quot;</span>)</pre></div></div></div></div>
<div class="slide" style="--ac1:0,212,255;--ac2:0,128,255"><div class="slide-header" style="border-color:rgba(0,212,255,.25)"><span class="slide-icon">⚙️</span><h2 style="color:#00d4ff">Tópico 4 — Arquitetura Transformer<span>Aula 1</span></h2><span class="slide-num">5/8</span></div><div class="slide-body"><div class="content-col"><p class="lead-text" style="border-color:#00d4ff">O mecanismo de Self-Attention é a base de todos os LLMs modernos (GPT, Llama, BERT).</p><ul class="bullet-list"><li>Self-Attention: cada token atende a todos os outros — captura dependências de longo alcance</li><li>Multi-Head Attention: múltiplas projeções paralelas de Q, K, V</li><li>Positional Encoding: injeta informação de posição (sem recorrência)</li><li>Encoder: compreensão (BERT) | Decoder: geração (GPT, Llama) | Encoder-Decoder: tradução (T5)</li></ul></div><div class="diagram-col">
<div class="diagram">
  <div class="d-flow">
    <span class="d-step">Input<br>tokens</span>
    <span class="d-arr">→</span>
    <span class="d-step cyan">Positional<br>Encoding</span>
    <span class="d-arr">→</span>
    <span class="d-step purple">Multi-Head<br>Attention</span>
    <span class="d-arr">→</span>
    <span class="d-step blue">Feed<br>Forward</span>
    <span class="d-arr">→</span>
    <span class="d-step green">Output<br>vectors</span>
  </div>
  <div class="d-note">🔑 Self-Attention: Q·Kᵀ/√d_k → softmax → ·V</div>
</div></div></div></div>
<div class="slide" style="--ac1:0,212,255;--ac2:0,128,255"><div class="slide-header" style="border-color:rgba(0,212,255,.25)"><span class="slide-icon">🤖</span><h2 style="color:#00d4ff">Tópico 5 — LLMs: GPT, Llama e Parâmetros<span>Aula 1</span></h2><span class="slide-num">6/8</span></div><div class="slide-body"><div class="content-col"><p class="lead-text" style="border-color:#00d4ff">Grandes Modelos de Linguagem são Transformers decoder-only treinados em trilhões de tokens.</p><ul class="bullet-list"><li>Llama 3.1 8B: open-source, roda localmente via vLLM, LGPL</li><li>temperature: controla aleatoriedade (0 = determinístico, 1 = criativo)</li><li>top_p: nucleus sampling — tokens cumulativos até p% de probabilidade</li><li>max_tokens: limite de geração — crucial para controlar custo e latência</li><li>vLLM: serving com PagedAttention — 24x throughput vs HuggingFace naive</li></ul></div><div class="code-col"><div class="code-wrap"><div class="code-header"><div class="code-dots"><span class="dot-r"></span><span class="dot-y"></span><span class="dot-g"></span></div>Python 3.11+</div><pre><span class="kw">import</span> openai

client = openai.<span class="cls">OpenAI</span>(
    api_key=<span class="str">&quot;EMPTY&quot;</span>,
    base_url=<span class="str">&quot;http://localhost:8000/v1&quot;</span>
)

response = client.chat.completions.<span class="fn">create</span>(
    model=<span class="str">&quot;meta-llama/Meta-Llama-3.1-8B-Instruct&quot;</span>,
    messages=[
        {<span class="str">&quot;role&quot;</span>: <span class="str">&quot;system&quot;</span>, <span class="str">&quot;content&quot;</span>: <span class="str">&quot;Você é um assistente jurídico.&quot;</span>},
        {<span class="str">&quot;role&quot;</span>: <span class="str">&quot;user&quot;</span>, <span class="str">&quot;content&quot;</span>: <span class="str">&quot;O que é habeas corpus?&quot;</span>}
    ],
    temperature=<span class="num">0.1</span>,
    max_tokens=<span class="num">512</span>
)
<span class="fn">print</span>(response.choices[<span class="num">0</span>].message.content)</pre></div></div></div></div>
<div class="slide" style="--ac1:0,212,255;--ac2:0,128,255"><div class="slide-header" style="border-color:rgba(0,212,255,.25)"><span class="slide-icon">🔍</span><h2 style="color:#00d4ff">Tópico 6 — O que é RAG?<span>Aula 1</span></h2><span class="slide-num">7/8</span></div><div class="slide-body"><div class="content-col"><div class="highlight-banner" style="border-color:#00d4ff;background:rgba(0,212,255,.07);color:#00d4ff">RAG = Retrieval-Augmented Generation. Combina busca em base de conhecimento com geração contextualizada pelo LLM.</div><ul class="bullet-list"><li>Proposto por Lewis et al. (2020) — NeurIPS, Meta AI Research</li><li>Fluxo: Query → Retriever → Contexto → LLM → Resposta fundamentada</li><li>Resolve: hallucination, knowledge cutoff e falta de fontes verificáveis</li><li>No contexto jurídico: o LLM cita o acórdão real, não inventa jurisprudência</li></ul></div><div class="diagram-col">
<div class="diagram">
  <div class="d-flow">
    <span class="d-step blue">Query</span>
    <span class="d-arr">→</span>
    <span class="d-step cyan">Embedding<br>BGE-M3</span>
    <span class="d-arr">→</span>
    <span class="d-step purple">OpenSearch<br>kNN</span>
    <span class="d-arr">→</span>
    <span class="d-step orange">Top-K<br>Chunks</span>
    <span class="d-arr">→</span>
    <span class="d-step">Prompt<br>+ Contexto</span>
    <span class="d-arr">→</span>
    <span class="d-step green">vLLM<br>Llama 3.1</span>
    <span class="d-arr">→</span>
    <span class="d-step blue">Resposta</span>
  </div>
</div></div></div></div>
<div class="slide" style="--ac1:0,212,255;--ac2:0,128,255"><div class="slide-header" style="border-color:rgba(0,212,255,.25)"><span class="slide-icon">🗺️</span><h2 style="color:#00d4ff">Tópico 7 — Panorama das 25 Técnicas RAG<span>Aula 1</span></h2><span class="slide-num">8/8</span></div><div class="slide-body"><div class="content-col"><p class="lead-text" style="border-color:#00d4ff">O curso cobre 25 técnicas RAG organizadas em 5 camadas do pipeline.</p><div class="map-grid"><div class="map-layer" style="border-color:#10b981;background:rgba(16,185,129,.06)"><span class="map-layer-name" style="color:#10b981">Ingestão</span><div class="map-techs"><span class="map-tech">Fixed Chunking</span><span class="map-tech">Recursive Split</span><span class="map-tech">Semantic Chunking</span><span class="map-tech">Docling</span><span class="map-tech">Sentence Window</span></div></div><div class="map-layer" style="border-color:#00d4ff;background:rgba(0,212,255,.06)"><span class="map-layer-name" style="color:#00d4ff">Indexação</span><div class="map-techs"><span class="map-tech">Dense (kNN)</span><span class="map-tech">Hybrid BM25+kNN</span><span class="map-tech">Neural Sparse</span><span class="map-tech">Parent-Child</span><span class="map-tech">RAPTOR</span></div></div><div class="map-layer" style="border-color:#7c3aed;background:rgba(124,58,237,.06)"><span class="map-layer-name" style="color:#7c3aed">Retrieval</span><div class="map-techs"><span class="map-tech">Multi-Query RAG</span><span class="map-tech">HyDE</span><span class="map-tech">RAG-Fusion</span><span class="map-tech">Step-Back</span><span class="map-tech">Contextual Retrieval</span></div></div><div class="map-layer" style="border-color:#f59e0b;background:rgba(245,158,11,.06)"><span class="map-layer-name" style="color:#f59e0b">Geração</span><div class="map-techs"><span class="map-tech">Self-RAG</span><span class="map-tech">CRAG</span><span class="map-tech">Agentic RAG</span><span class="map-tech">Adaptive RAG</span><span class="map-tech">Graph RAG</span></div></div><div class="map-layer" style="border-color:#ef4444;background:rgba(239,68,68,.06)"><span class="map-layer-name" style="color:#ef4444">Avaliação</span><div class="map-techs"><span class="map-tech">RAGAS</span><span class="map-tech">DeepEval</span><span class="map-tech">LangFuse</span><span class="map-tech">LLM-as-Judge</span><span class="map-tech">DSPy</span></div></div></div></div></div></div>
<div class="slide" style="--ac1:0,212,255;--ac2:0,128,255"><div class="slide-header" style="border-color:rgba(0,212,255,.25)"><span class="slide-icon">📚</span><h2 style="color:#00d4ff">Recursos da Aula<span>Aula 1</span></h2><span class="slide-num">Recursos</span></div><div class="slide-body"><div class="content-col"><div class="resources-grid"><div class="resource-section"><div class="resource-section-title">💡 Exemplos (1)</div><div class="resource-cards"><a class="resource-card" href="aula1/exemplos/EXEMPLO_Pipeline_RAG_Minimo.ipynb" target="_blank"><span class="rc-icon">💡</span><span><span class="rc-name">EXEMPLO Pipeline RAG Minimo</span><br><span class="rc-type">IPYNB · Exemplo</span></span></a></div></div><div class="resource-section"><div class="resource-section-title">🔬 Laboratórios (5)</div><div class="resource-cards"><a class="resource-card" href="aula1/labs/LAB1_OpenSearch_Docker.ipynb" target="_blank"><span class="rc-icon">🔬</span><span><span class="rc-name">LAB1 OpenSearch Docker</span><br><span class="rc-type">IPYNB · Lab</span></span></a><a class="resource-card" href="aula1/labs/LAB2_Setup_Colab_Ambiente.ipynb" target="_blank"><span class="rc-icon">🔬</span><span><span class="rc-name">LAB2 Setup Colab Ambiente</span><br><span class="rc-type">IPYNB · Lab</span></span></a><a class="resource-card" href="aula1/labs/LAB3_vLLM_LLM_Local.ipynb" target="_blank"><span class="rc-icon">🔬</span><span><span class="rc-name">LAB3 vLLM LLM Local</span><br><span class="rc-type">IPYNB · Lab</span></span></a><a class="resource-card" href="aula1/labs/LAB4_LangFuse_Observabilidade.ipynb" target="_blank"><span class="rc-icon">🔬</span><span><span class="rc-name">LAB4 LangFuse Observabilidade</span><br><span class="rc-type">IPYNB · Lab</span></span></a><a class="resource-card" href="aula1/labs/LAB5_Embeddings_BGE_M3_UMAP.ipynb" target="_blank"><span class="rc-icon">🔬</span><span><span class="rc-name">LAB5 Embeddings BGE M3 UMAP</span><br><span class="rc-type">IPYNB · Lab</span></span></a></div></div><div class="resource-section"><div class="resource-section-title">📦 Datasets (1)</div><div class="resource-cards"><a class="resource-card" href="aula1/datasets/corpus_juridico_aula1.json" target="_blank"><span class="rc-icon">📦</span><span><span class="rc-name">corpus juridico aula1.json</span><br><span class="rc-type">JSON · Dataset</span></span></a></div></div></div></div></div></div>
